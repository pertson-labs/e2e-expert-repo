# ── UPDATE: Sample node — title and description revised ─────────────────────
DELETE {
  GRAPH ?g {
    narr:Sample_ZypherionDBDecision_20260406
      dct:title ?oldTitle ;
      dct:description ?oldDesc ;
      narr:inputLength ?oldLen .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T140000Z {
    narr:Sample_MeridianDBDecision_20260406
      a narr:Sample ;
      dct:title "Database Decision REVISED: Switching from Zypherion to Meridian" ;
      dct:created "2026-04-06"^^xsd:date ;
      dct:description "Revised meeting note recording CTO Quinton Fairweather's decision to supersede the Zypherion adoption and switch to Meridian, citing critical gaps in Zypherion streaming ingestion and Meridian's native batch-and-streaming capability. Q3 2026 migration window retained." ;
      narr:inputLength 590 .
  }
}
WHERE {
  GRAPH ?g {
    narr:Sample_ZypherionDBDecision_20260406
      dct:title ?oldTitle ;
      dct:description ?oldDesc ;
      narr:inputLength ?oldLen .
  }
} ;

# ── UPDATE: Narrative — theme and note superseded by Meridian adoption ───────
DELETE {
  GRAPH ?g {
    narr:Narrative_ZypherionAnalyticsAdoption
      narr:theme ?oldTheme ;
      skos:note ?oldNote ;
      dct:source ?oldSrc .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T140000Z {
    narr:Narrative_MeridianAnalyticsAdoption
      a narr:Narrative ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:broader narr:StackOverview ;
      skos:note "The organisation has reversed its Zypherion decision and is now adopting Meridian for analytics, driven by critical gaps in Zypherion's streaming ingestion and Meridian's native batch-and-streaming support. Q3 2026 migration window is retained." ;
      narr:theme "Superseding Zypherion with Meridian as the analytics database due to streaming ingestion gaps" ;
      narr:supersedes narr:Narrative_ZypherionAnalyticsAdoption .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_ZypherionAnalyticsAdoption
      narr:theme ?oldTheme ;
      skos:note ?oldNote ;
      dct:source ?oldSrc .
  }
} ;

