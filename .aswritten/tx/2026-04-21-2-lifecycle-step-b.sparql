# ── INSERT DATA: New entities with no snapshot match ────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260406T140000Z {

    # New claim: Meridian batch+streaming capability
    narr:Claim_MeridianBatchStreamingCapability
      a narr:Claim ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:note "Meridian handles both batch and streaming ingestion natively, which is the key technical differentiator cited by the CTO." ;
      narr:aboutNode narr:Narrative_MeridianAnalyticsAdoption ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Claim_MeridianDBChoice .

    # Observation: Quinton's direct statement (revised)
    narr:Obs_QuintonMeridianStatement
      a narr:Observation ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:broader narr:PositioningThesis ;
      skos:note "CTO direct statement announcing the switch from Zypherion to Meridian, citing streaming ingestion gaps and native batch+streaming support." ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 196 ;
        oa:end 372
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "We evaluated Zypherion further and found critical gaps in its streaming ingestion. We are now switching to Meridian instead." ;
        oa:prefix "Quinton: \"" ;
        oa:suffix " Meridian handles both batch and streaming natively.\""
      ] .

    # Observation: Supersession statement
    narr:Obs_SupersessionStatement
      a narr:Observation ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:broader narr:DesignTradeoffs ;
      skos:note "Explicit statement that this revised decision supersedes the prior Zypherion adoption decision." ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 374 ;
        oa:end 422
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "This supersedes the previous Zypherion decision." ;
        oa:prefix "natively.\"\n\n" ;
        oa:suffix "\n\nKey decisions:"
      ] .

    # Style Observation 1: Direct authoritative tone
    narr:StyleObs_DirectDeclarativeTone
      a narr:StyleObservation ;
      skos:broader narr:ToneAuthoritative ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:note "Declarative present-tense assertions with no hedging: 'We are now switching to Meridian instead.'" ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_MeridianDBDecision_20260406 ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 253 ;
          oa:end 320
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "We are now switching to Meridian instead." ;
          oa:prefix "its streaming ingestion. " ;
          oa:suffix " Meridian handles both"
        ]
      ] .

    # Style Observation 2: Bold key-decision formatting
    narr:StyleObs_BoldKeyDecisions
      a narr:StyleObservation ;
      skos:broader narr:PunctuationTypography ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:note "Bold labels (**Database**, **Reason**, **Timeline**) structure the key-decisions list, a consistent formatting convention from the prior decision note." ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_MeridianDBDecision_20260406 ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 438 ;
          oa:end 590
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "- **Database**: Meridian replaces Zypherion for analytics" ;
          oa:prefix "Key decisions:\n" ;
          oa:suffix "\n- **Reason**: Zypherion lacks"
        ]
      ] .

    # Style Observation 3: Supersession rhetoric
    narr:StyleObs_SupersessionRhetoric
      a narr:StyleObservation ;
      skos:broader narr:ToneDirectPersonal ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:note "Single-sentence supersession declaration functions as a rhetorical reset, formally closing the prior decision before opening the new one." ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_MeridianDBDecision_20260406 ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 374 ;
          oa:end 422
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "This supersedes the previous Zypherion decision." ;
          oa:prefix "natively.\"\n\n" ;
          oa:suffix "\n\nKey decisions:"
        ]
      ] .

  }
}