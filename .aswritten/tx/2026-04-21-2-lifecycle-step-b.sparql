    narr:StyleMetrics_MeridianDBDecision
      a narr:StyleMetrics ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:broader narr:StyleMetrics ;
      skos:note "Short declarative sentences; very high active-voice ratio; low jargon (streaming ingestion, batch, analytics pipeline). Register: executive decision reversal note. Supersession language adds rhetorical weight." ;
