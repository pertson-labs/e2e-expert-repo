# ── New Observation: Quinton's direct statement on Meridian ──────────────────
INSERT DATA {
  GRAPH narr:Tx_20260406T120000Z {
    narr:Obs_QuintonMeridianStatement a narr:Observation ;
      dct:source  narr:Sample_MeridianDecision_20260406 ;
      skos:broader narr:Quotes ;
      skos:note   "CTO direct statement reversing Zypherion decision and announcing Meridian adoption with streaming rationale." ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 196 ;
        oa:end   363
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact  "We evaluated Zypherion further and found critical gaps in its streaming ingestion. We are now switching to Meridian instead. Meridian handles both batch and streaming natively." ;
        oa:prefix "Quinton: \"" ;
        oa:suffix "\""
      ] .
  }
} ;

