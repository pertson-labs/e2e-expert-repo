  GRAPH narr:Tx_20260406T120000Z {
    narr:Claim_ZypherionDatabaseChoice
      skos:note             "Meridian has replaced Zypherion as the formally selected analytics database. The prior Zypherion selection is explicitly superseded by this revised decision." ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      dct:source            narr:Sample_MeridianDecision_20260406 ;
      narr:aboutNode        narr:Narrative_ZypherionAdoption ;
      narr:supports         narr:Narrative_ZypherionAdoption .
  }
}
WHERE {
  GRAPH ?g {
    narr:Claim_ZypherionDatabaseChoice
      skos:note             ?oldNote ;
      narr:hasConvictionLevel ?oldLevel ;
      dct:source            ?oldSource .
  }
} ;

