# ── New Sample for the revised document ─────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260406T120000Z {
    narr:Sample_MeridianDecision_20260406 a narr:Sample ;
      dct:title "Database Decision REVISED: Switching from Zypherion to Meridian" ;
      dct:description "Revised meeting note in which CTO Quinton Fairweather supersedes the prior Zypherion decision, selecting Meridian as the analytics database due to Zypherion's critical streaming ingestion gaps. Q3 2026 migration window retained." ;
      dct:created "2026-04-06"^^xsd:date ;
      narr:inputLength 541 .
  }
} ;

# ── UPDATE narr:Narrative_ZypherionAdoption → now Meridian adoption ──────────
# Justified: memory explicitly states "switching to Meridian instead" and
# "This supersedes the previous Zypherion decision" — functional change to theme/note.
DELETE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption
      narr:theme ?oldTheme ;
      skos:note  ?oldNote ;
      dct:source ?oldSource .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T120000Z {
    narr:Narrative_ZypherionAdoption
      narr:theme "Technology adoption: replacing Zypherion with Meridian as the analytics database" ;
      skos:note  "The organisation reversed its Zypherion decision after discovering critical streaming ingestion gaps. Meridian, which handles both batch and streaming natively, is now the selected analytics database. Q3 2026 migration window is retained." ;
      dct:source narr:Sample_MeridianDecision_20260406 .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption
      narr:theme ?oldTheme ;
      skos:note  ?oldNote ;
      dct:source ?oldSource .
  }
} ;

# ── UPDATE narr:Claim_ZypherionDatabaseChoice → Meridian is now the choice ───
# Justified: memory states "Meridian replaces Zypherion for analytics" — explicit retraction
# of Zypherion selection; functional change to a single-valued decision claim.
DELETE {
  GRAPH ?g {
    narr:Claim_ZypherionDatabaseChoice
      skos:note             ?oldNote ;
      narr:hasConvictionLevel ?oldLevel ;
      dct:source            ?oldSource .
  }
}
