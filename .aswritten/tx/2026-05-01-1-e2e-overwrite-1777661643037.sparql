PREFIX narr: <https://aswritten.ai/narrative#>
PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX dct:  <http://purl.org/dc/terms/>
PREFIX xsd:  <http://www.w3.org/2001/XMLSchema#>
PREFIX oa:   <http://www.w3.org/ns/oa#>

# Transaction provenance (default graph)
INSERT DATA {
  narr:Tx_20250115T120000Z a prov:Activity ;
    prov:generatedAtTime "2025-01-15T12:00:00Z"^^xsd:dateTime ;
    prov:wasAssociatedWith "aswritten.ai" ;
    prov:wasAttributedTo "n8n.aswritten.ai" ;
    narr:originPath "unknown" ;
    narr:originRef "unknown" ;
    dct:title "Extraction: First version stub document" ;
    prov:generated
      narr:Sample_FirstVersionStub,
      narr:Narrative_FirstVersionDeclaration,
      narr:Observation_FirstVersionPhrase,
      narr:StyleObs_MinimalRegister,
      narr:StyleObs_ImperativeVersionLabel,
      narr:StyleObs_FrontmatterReviewerPattern,
      narr:StyleMetrics_FirstVersionStub .
} ;

# Extracted entities (named graph)
INSERT DATA {
  GRAPH narr:Tx_20250115T120000Z {

    # ── Sample ──────────────────────────────────────────────────
    narr:Sample_FirstVersionStub a narr:Sample ;
      dct:title "First version stub document" ;
      narr:inputLength 52 ;
      dct:description "Minimal stub document with YAML frontmatter (reviewer metadata) and a single body phrase 'First version'. No substantive narrative content beyond version declaration." .

    # ── Narrative ───────────────────────────────────────────────
    narr:Narrative_FirstVersionDeclaration a narr:Narrative ;
      dct:source narr:Sample_FirstVersionStub ;
      narr:theme "Initial document version declaration" ;
      skos:broader narr:NarrativeDrivenRoadmap ;
      skos:note "The document declares itself as 'First version' — a versioning milestone marker with no elaborated content. The frontmatter assigns a reviewer role, suggesting a review-gated workflow." .

    # ── Observation: 'First version' phrase ─────────────────────
    narr:Observation_FirstVersionPhrase a narr:Observation ;
      skos:broader narr:Milestones ;
      dct:source narr:Sample_FirstVersionStub ;
      skos:note "The sole body content is the phrase 'First version', functioning as a version milestone marker." ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 44 ;
        oa:end 57
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "First version" ;
        oa:prefix "\n\n" ;
        oa:suffix ""
      ] .

    # ── Style Observation 1: Minimal / stub register ─────────────
    narr:StyleObs_MinimalRegister a narr:StyleObservation ;
      skos:broader narr:RegisterFormality ;
      dct:source narr:Sample_FirstVersionStub ;
      skos:note "Extremely minimal register: the entire body is two words. No sentences, no elaboration. Signals a placeholder or scaffold document." ;
      rdf:value false ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_FirstVersionStub ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 44 ;
          oa:end 57
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "First version" ;
          oa:prefix "\n\n" ;
          oa:suffix ""
        ]
      ] .

    # ── Style Observation 2: Version label as imperative noun phrase
    narr:StyleObs_ImperativeVersionLabel a narr:StyleObservation ;
      skos:broader narr:NamingConventions ;
      dct:source narr:Sample_FirstVersionStub ;
      skos:note "'First version' uses a noun-phrase version label convention (ordinal + noun) rather than semantic versioning (e.g., v1.0.0). Indicates informal or early-stage document lifecycle conventions." ;
      rdf:value false ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_FirstVersionStub ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 44 ;
          oa:end 57
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "First version" ;
          oa:prefix "\n\n" ;
          oa:suffix ""
        ]
      ] .

    # ── Style Observation 3: YAML frontmatter reviewer pattern ───
    narr:StyleObs_FrontmatterReviewerPattern a narr:StyleObservation ;
      skos:broader narr:EditorialRules ;
      dct:source narr:Sample_FirstVersionStub ;
      skos:note "YAML frontmatter declares a 'reviewers' list, indicating a structured review-gate workflow convention embedded in document metadata. Reviewer email redacted per PII policy." ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_FirstVersionStub ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 0 ;
          oa:end 42
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "---\nreviewers:\n  - [REDACTED]\n---" ;
          oa:prefix "" ;
          oa:suffix "\n\nFirst version"
        ]
      ] .

    # ── Style Metrics ────────────────────────────────────────────
    narr:StyleMetrics_FirstVersionStub a narr:StyleMetrics ;
      skos:broader narr:StyleMetrics ;
      dct:source narr:Sample_FirstVersionStub ;
      narr:AverageSentenceLength 2 ;
      narr:ActiveVoiceRatio "1.0"^^xsd:decimal ;
      narr:JargonDensity "0.0"^^xsd:decimal ;
      skos:note "Stub document: 2-word body, no sentences, no jargon. Metrics reflect placeholder content only." .

  }
}