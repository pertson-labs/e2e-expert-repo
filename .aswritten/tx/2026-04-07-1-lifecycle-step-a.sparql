      dct:source narr:Sample_ZypherionDecision_20260406 ;
      skos:note "Migration to Zypherion is planned to start in Q3 2026 (next quarter from the meeting date of 2026-04-06)." .

    # ── Observation (verbatim quote) ─────────────────────────────
    narr:Obs_QuintonAdoptionQuote a narr:Observation ;
      skos:broader narr:Quotes ;
      dct:source narr:Sample_ZypherionDecision_20260406 ;
      skos:note "CTO direct statement announcing the Zypherion adoption decision, performance rationale, and migration timeline." ;
      oa:hasSelector [
