    # SO-2: Bold labels for structured key-decision list
    narr:StyleObs_BoldKeyDecisionLabels a narr:StyleObservation ;
      skos:broader narr:PunctuationTypography ;
      dct:source narr:Sample_ZypherionDecision_20260406 ;
      skos:note "Markdown bold used as category labels in a bullet list (e.g., **Database**, **Performance**, **Timeline**) — a structured, scannable decision-log format." ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_ZypherionDecision_20260406 ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
