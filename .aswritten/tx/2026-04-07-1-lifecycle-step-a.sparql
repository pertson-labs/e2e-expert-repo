      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Claim_ZypherionDBChoice ;
      dct:source narr:Sample_ZypherionDecision_20260406 ;
      skos:note "Zypherion handles columnar queries 15x faster than the current setup — asserted by the CTO but not yet independently verified post-migration." .

    narr:Claim_ZypherionMigrationQ3 a narr:Claim ;
