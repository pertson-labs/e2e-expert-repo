  GRAPH ?g {
    narr:Narrative_ZypherionAdoption
      narr:theme ?oldTheme ;
      skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T140000Z {
    narr:Narrative_ZypherionAdoption
      narr:theme "Technology adoption decision: Zypherion analytics database — SUPERSEDED by Meridian" ;
      skos:note "Originally: adopting Zypherion for analytics (15x columnar query performance, Q3 2026 migration). SUPERSEDED 2026-04-06: critical streaming ingestion gaps discovered; Meridian selected instead. See narr:Narrative_MeridianAdoption." .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption
      narr:theme ?oldTheme ;
      skos:note ?oldNote .
  }
} ;

