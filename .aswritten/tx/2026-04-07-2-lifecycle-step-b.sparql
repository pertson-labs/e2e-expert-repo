# ── New Sample node ──────────────────────────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260406T140000Z {
    narr:Sample_MeridianDecision_20260406
      a narr:Sample ;
      dct:title "Database Decision REVISED: Switching from Zypherion to Meridian" ;
      dct:description "Revised meeting note in which CTO Quinton Fairweather retracts the Zypherion decision and selects Meridian instead, citing critical streaming ingestion gaps in Zypherion. Migration window remains Q3 2026." ;
      dct:created "2026-04-06"^^xsd:date ;
      narr:inputLength 541 .
  }
} ;

# ── New Narrative: Meridian adoption ────────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260406T140000Z {
    narr:Narrative_MeridianAdoption
      a narr:Narrative ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      skos:broader narr:StackOverview ;
      narr:theme "Technology adoption decision: replacing Zypherion with Meridian for analytics due to streaming ingestion gap" ;
      skos:note "The organisation reverses its Zypherion decision and adopts Meridian as the analytics database. Meridian handles both batch and streaming natively; Zypherion was found to have critical gaps in streaming ingestion. Migration window remains Q3 2026." ;
      narr:supersedes narr:Narrative_ZypherionAdoption .
  }
} ;

