# ── UPDATE: Actor_QuintonFairweather_CTO note ────────────────────
DELETE {
  GRAPH ?g {
    narr:Actor_QuintonFairweather_CTO skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T140000Z {
    narr:Actor_QuintonFairweather_CTO
      skos:note "CTO; announced the Zypherion analytics database adoption decision on 2026-04-06, then issued a revised decision on the same date switching to Meridian after finding critical streaming ingestion gaps in Zypherion." .
  }
}
WHERE {
  GRAPH ?g {
    narr:Actor_QuintonFairweather_CTO skos:note ?oldNote .
  }
} ;

# ── DELETE: Claim_ZypherionPerformance15x (contradicted) ─────────
# Justification: memory explicitly supersedes the Zypherion decision;
# the 15x columnar performance claim was Zypherion-specific and is
# directly contradicted by the switch away from Zypherion.
DELETE WHERE {
  GRAPH ?g {
    narr:Claim_ZypherionPerformance15x ?p ?o .
  }
} ;

# ── INSERT: New Claim — Zypherion streaming ingestion gap ─────────
INSERT DATA {
  GRAPH narr:Tx_20260406T140000Z {
    narr:Claim_ZypherionStreamingGap a narr:Claim ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      skos:note "Zypherion has critical gaps in streaming ingestion, making it unsuitable for the analytics pipeline. This is the stated reason for switching to Meridian." ;
      narr:aboutNode narr:Narrative_ZypherionAdoption ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Claim_ZypherionDatabaseSelection .
  }
} ;

# ── INSERT: Observations ─────────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260406T140000Z {

    narr:Obs_SupersessionStatement a narr:Observation ;
      skos:broader narr:DesignTradeoffs ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      skos:note "Explicit supersession of prior Zypherion decision" ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 374 ;
        oa:end 422
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "This supersedes the previous Zypherion decision." ;
        oa:prefix "Meridian handles both batch and streaming natively.\"\n\n" ;
        oa:suffix "\n\nKey decisions:"
      ] .

    narr:Obs_MeridianStreamingCapability a narr:Observation ;
      skos:broader narr:DataIntegrationFlows ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      skos:note "CTO states Meridian handles both batch and streaming natively — the key differentiator over Zypherion" ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 321 ;
        oa:end 372
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "Meridian handles both batch and streaming natively." ;
        oa:prefix "We are now switching to Meridian instead.\n" ;
        oa:suffix "\"\n\nThis supersedes"
      ] .

    narr:Obs_MeridianKeyDecisions a narr:Observation ;
      skos:broader narr:StackOverview ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      skos:note "Structured key decisions: Meridian replaces Zypherion; reason is streaming gap; timeline unchanged at Q3 2026" ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 438 ;
        oa:end 591
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "- **Database**: Meridian replaces Zypherion for analytics\n- **Reason**: Zypherion lacks streaming ingestion\n- **Timeline**: Same Q3 2026 migration window" ;
        oa:prefix "Key decisions:\n" ;
        oa:suffix ""
      ] .
  }
} ;

