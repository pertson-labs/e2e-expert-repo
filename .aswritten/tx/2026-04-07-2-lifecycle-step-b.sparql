# ── New Sample for the revised document ──────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260406T140000Z {
    narr:Sample_MeridianDecision_20260406 a narr:Sample ;
      dct:title "Database Decision REVISED: Switching from Zypherion to Meridian" ;
      dct:description "Revised meeting notes from Quinton Fairweather (CTO) announcing the switch from Zypherion to Meridian for the analytics pipeline, citing critical gaps in Zypherion streaming ingestion. Explicitly supersedes the prior Zypherion decision." ;
      dct:created "2026-04-06"^^xsd:date ;
      narr:inputLength "591"^^xsd:integer .
  }
} ;

# ── UPDATE: Narrative_ZypherionAdoption → now Meridian adoption ──
DELETE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption
      narr:theme ?oldTheme ;
      skos:note ?oldNote ;
      dct:source ?oldSource .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T140000Z {
    narr:Narrative_ZypherionAdoption
      narr:theme "Technology adoption: Meridian replaces Zypherion as analytics database due to streaming ingestion gaps" ;
      skos:note "The organisation has reversed its Zypherion decision and is now adopting Meridian as its analytics pipeline database. Zypherion was found to have critical gaps in streaming ingestion; Meridian handles both batch and streaming natively. Migration remains Q3 2026. This supersedes the prior Zypherion adoption narrative." ;
      dct:source narr:Sample_MeridianDecision_20260406 .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption
      narr:theme ?oldTheme ;
      skos:note ?oldNote ;
      dct:source ?oldSource .
  }
} ;

# ── UPDATE: Claim_ZypherionDatabaseSelection → Meridian selected ─
DELETE {
  GRAPH ?g {
    narr:Claim_ZypherionDatabaseSelection
      skos:note ?oldNote ;
      dct:source ?oldSource ;
      narr:hasConvictionLevel ?oldLevel .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T140000Z {
    narr:Claim_ZypherionDatabaseSelection
      skos:note "Meridian has been selected as the database for the analytics pipeline, replacing Zypherion. Stated as a decided fact by the CTO in the revised decision document dated 2026-04-06." ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      narr:hasConvictionLevel narr:Conviction_Boulder .
  }
}
WHERE {
  GRAPH ?g {
    narr:Claim_ZypherionDatabaseSelection
      skos:note ?oldNote ;
      dct:source ?oldSource ;
      narr:hasConvictionLevel ?oldLevel .
  }
} ;

# ── UPDATE: Claim_MigrationTimelineQ3_2026 → now for Meridian ────
DELETE {
  GRAPH ?g {
    narr:Claim_MigrationTimelineQ3_2026
      skos:note ?oldNote ;
      dct:source ?oldSource .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T140000Z {
    narr:Claim_MigrationTimelineQ3_2026
      skos:note "Migration to Meridian (replacing Zypherion) remains on the same Q3 2026 window. Stated by CTO in the revised decision document." ;
