# ── New Sample for the revised document ─────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260406T120000Z {
    narr:Sample_MeridianDBDecision_20260406 a narr:Sample ;
      dct:title "Database Decision REVISED: Switching from Zypherion to Meridian" ;
      dct:created "2026-04-06"^^xsd:date ;
      dct:description "Revised meeting note in which CTO Quinton Fairweather explicitly supersedes the prior Zypherion decision and selects Meridian as the analytics database, citing critical streaming ingestion gaps in Zypherion. Q3 2026 migration window retained." ;
      narr:inputLength "469"^^xsd:integer .
  }
} ;

# ── UPDATE: narr:Narrative_ZypherionAdoption → now Meridian adoption ────────
# Justified by: memory states "Meridian replaces Zypherion" and "supersedes the previous Zypherion decision"
DELETE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption
      narr:theme ?oldTheme ;
      skos:note ?oldNote ;
      dct:source ?oldSource .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T120000Z {
    narr:Narrative_ZypherionAdoption
      narr:theme "Technology adoption: Meridian replaces Zypherion as analytics pipeline database due to streaming ingestion gaps" ;
      skos:note "The organisation has revised its database decision: Meridian now replaces Zypherion for the analytics pipeline. Zypherion was found to have critical gaps in streaming ingestion; Meridian handles both batch and streaming natively. Migration remains scheduled for Q3 2026. This supersedes the prior Zypherion adoption decision." ;
      dct:source narr:Sample_MeridianDBDecision_20260406 .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption narr:theme ?oldTheme .
    OPTIONAL { narr:Narrative_ZypherionAdoption skos:note ?oldNote . }
    OPTIONAL { narr:Narrative_ZypherionAdoption dct:source ?oldSource . }
  }
} ;

# ── UPDATE: narr:Claim_DBChoiceZypherion → Meridian is now the chosen DB ────
# Justified by: "We are now switching to Meridian instead" + "Database: Meridian replaces Zypherion"
DELETE {
  GRAPH ?g {
    narr:Claim_DBChoiceZypherion
      skos:note ?oldNote ;
      narr:hasConvictionLevel ?oldLevel ;
      dct:source ?oldSource .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T120000Z {
    narr:Claim_DBChoiceZypherion
      skos:note "REVISED: Meridian is now the selected database for the analytics pipeline, replacing Zypherion. CTO Quinton Fairweather explicitly superseded the prior Zypherion decision on 2026-04-06." ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      dct:source narr:Sample_MeridianDBDecision_20260406 .
  }
}
WHERE {
  GRAPH ?g {
    narr:Claim_DBChoiceZypherion narr:hasConvictionLevel ?oldLevel .
    OPTIONAL { narr:Claim_DBChoiceZypherion skos:note ?oldNote . }
    OPTIONAL { narr:Claim_DBChoiceZypherion dct:source ?oldSource . }
  }
} ;

# ── DELETE: narr:Claim_15xColumnarPerformance (superseded rationale) ─────────
