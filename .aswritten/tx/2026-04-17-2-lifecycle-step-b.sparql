# and is explicitly superseded by the revised decision document
DELETE {
  GRAPH ?g {
    narr:Claim_15xColumnarPerformance ?p ?o .
  }
}
WHERE {
  GRAPH ?g {
    narr:Claim_15xColumnarPerformance ?p ?o .
  }
} ;

# ── UPDATE: narr:Claim_MigrationQ32026 → same window but now for Meridian ───
# Justified by: "Same Q3 2026 migration window" — timeline retained but subject changed
DELETE {
  GRAPH ?g {
    narr:Claim_MigrationQ32026
      skos:note ?oldNote ;
      narr:aboutNode ?oldAbout ;
      dct:source ?oldSource .
  }
}
