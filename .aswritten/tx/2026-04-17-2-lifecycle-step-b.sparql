    narr:Claim_MigrationQ32026 narr:aboutNode ?oldAbout .
    OPTIONAL { narr:Claim_MigrationQ32026 skos:note ?oldNote . }
    OPTIONAL { narr:Claim_MigrationQ32026 dct:source ?oldSource . }
  }
} ;

# ── INSERT: New claims specific to the revised decision ─────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260406T120000Z {

    # New DB choice claim for Meridian
    narr:Claim_DBChoiceMeridian a narr:Claim ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:note "Meridian is the newly selected database for the analytics pipeline, chosen because it handles both batch and streaming ingestion natively." ;
      narr:aboutNode narr:Narrative_ZypherionAdoption ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_ZypherionAdoption .

    # Zypherion streaming gap — the explicit reason for the switch
    narr:Claim_ZypherionStreamingGap a narr:Claim ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:note "Zypherion has critical gaps in streaming ingestion, which was the decisive technical reason for abandoning it in favour of Meridian." ;
      narr:aboutNode narr:Narrative_ZypherionAdoption ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Claim_DBChoiceMeridian .

    # Retained migration timeline, now explicitly for Meridian
    narr:Claim_MigrationQ32026_Meridian a narr:Claim ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:note "The Q3 2026 migration window is retained for the Meridian rollout, unchanged from the original Zypherion plan." ;
      narr:aboutNode narr:Narrative_ZypherionAdoption ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Claim_DBChoiceMeridian .

    # ── Style Observations ────────────────────────────────────────────────

    # SO1: Direct declarative announcement tone
    narr:StyleObs_DirectDeclarative a narr:StyleObservation ;
      skos:broader narr:ToneDirectPersonal ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:note "Quinton's statement opens with 'We evaluated … and found' — direct, first-person plural, declarative. No hedging." ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_MeridianDBDecision_20260406 ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 175 ;
          oa:end 280
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "We evaluated Zypherion further and found critical gaps in its streaming ingestion." ;
          oa:prefix "Quinton: \"" ;
          oa:suffix " We are now switching"
        ]
      ] .

    # SO2: Explicit supersession marker — rhetorical device signalling authority
    narr:StyleObs_SupersedesMarker a narr:StyleObservation ;
      skos:broader narr:ToneAuthoritative ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:note "The phrase 'This supersedes the previous Zypherion decision' is a formal retraction marker — authoritative, unambiguous, institutional register." ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_MeridianDBDecision_20260406 ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 338 ;
          oa:end 385
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "This supersedes the previous Zypherion decision." ;
          oa:prefix "natively.\"\n\n" ;
          oa:suffix "\n\nKey decisions:"
        ]
      ] .

    # SO3: Bold key-decision formatting — structured list with bold labels
    narr:StyleObs_BoldKeyDecisions a narr:StyleObservation ;
      skos:broader narr:NamingConventions ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:note "Key decisions are formatted as a bold-label list (e.g., '**Database**:', '**Reason**:', '**Timeline**:') — a structured, scannable operational style." ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_MeridianDBDecision_20260406 ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 387 ;
          oa:end 469
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "- **Database**: Meridian replaces Zypherion for analytics" ;
          oa:prefix "Key decisions:\n" ;
          oa:suffix "\n- **Reason**:"
        ]
      ] .

    # ── Style Metrics ─────────────────────────────────────────────────────
    narr:StyleMetrics_MeridianDBDecision a narr:StyleMetrics ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:broader narr:StyleMetrics ;
      skos:note "Short, declarative sentences. High active voice. Moderate technical jargon (streaming ingestion, batch, analytics). Formal-operational register with explicit retraction language. Structured bullet list for key decisions." ;
      narr:AverageSentenceLength "11"^^xsd:integer ;
      narr:ActiveVoiceRatio "0.92"^^xsd:decimal ;
      narr:JargonDensity "0.14"^^xsd:decimal .
  }
}