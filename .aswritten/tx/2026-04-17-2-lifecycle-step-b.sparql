  GRAPH narr:Tx_20260406T120000Z {
    narr:Claim_MigrationQ32026
      skos:note "Migration to Meridian (replacing Zypherion) is scheduled for Q3 2026 — the same window as the prior Zypherion plan. Confirmed in the revised decision note of 2026-04-06." ;
      narr:aboutNode narr:Narrative_ZypherionAdoption ;
      dct:source narr:Sample_MeridianDBDecision_20260406 .
  }
}
WHERE {
