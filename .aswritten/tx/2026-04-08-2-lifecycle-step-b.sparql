# ── New Sample for the revised document ─────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260406T140000Z {
    narr:Sample_MeridianDecision_20260406 a narr:Sample ;
      dct:title "Database Decision REVISED: Switching from Zypherion to Meridian" ;
      dct:created "2026-04-06"^^xsd:date ;
      narr:inputLength "594"^^xsd:integer ;
      skos:note "Revised meeting note superseding the original Zypherion decision. CTO Quinton Fairweather announces switch to Meridian due to critical streaming ingestion gaps in Zypherion. Q3 2026 migration window retained." .
  }
} ;

# ── UPDATE: narr:Narrative_ZypherionAdoption ────────────────────────────────
# Memory explicitly supersedes Zypherion adoption; Meridian is now the chosen DB.
# Temporal supersession + explicit retraction: "This supersedes the previous Zypherion decision."
DELETE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption narr:theme ?oldTheme ;
      skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T140000Z {
    narr:Narrative_ZypherionAdoption narr:theme "Technology pivot driven by capability gap: streaming ingestion" ;
      skos:note "REVISED 2026-04-06: The organisation is switching from Zypherion to Meridian for analytics. Zypherion was found to have critical gaps in streaming ingestion; Meridian handles both batch and streaming natively. Migration remains Q3 2026. Supersedes original Zypherion adoption decision." .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption narr:theme ?oldTheme ;
      skos:note ?oldNote .
  }
} ;

