    prov:generated narr:Sample_TestReview_20250522, narr:StyleObservation_FrontmatterYAML, narr:StyleObservation_DashesSeparator, narr:StyleObservation_ReviewerMetadata, narr:StyleMetrics_TestReview_20250522 .
} ;

# Extracted entities (named graph)
INSERT DATA {
  GRAPH narr:Tx_20250522T150000Z {
    narr:Sample_TestReview_20250522 a narr:Sample ;
      dct:title "Test Review Header" ;
      narr:inputLength 48 .

    narr:StyleObservation_FrontmatterYAML a narr:StyleObservation ;
      skos:broader narr:OrthographySpelling ;
      dct:source narr:Sample_TestReview_20250522 ;
      skos:note "Use of YAML frontmatter for metadata" ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_TestReview_20250522 ;
        oa:hasSelector [ a oa:TextPositionSelector ; oa:start 0 ; oa:end 44 ] ;
        oa:hasSelector [ a oa:TextQuoteSelector ; oa:exact "reviewers:\n  - test+expert-gh@aswritten.ai" ; oa:prefix "---" ; oa:suffix "---" ]
      ] .

    narr:StyleObservation_DashesSeparator a narr:StyleObservation ;
      skos:broader narr:PunctuationTypography ;
      dct:source narr:Sample_TestReview_20250522 ;
      skos:note "Triple-dash separators for document sections" ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_TestReview_20250522 ;
        oa:hasSelector [ a oa:TextPositionSelector ; oa:start 0 ; oa:end 3 ] ;
        oa:hasSelector [ a oa:TextQuoteSelector ; oa:exact "---" ; oa:suffix "reviewers" ]
      ] .

    narr:StyleObservation_ReviewerMetadata a narr:StyleObservation ;
      skos:broader narr:EditorialRules ;
      dct:source narr:Sample_TestReview_20250522 ;
      skos:note "Explicit reviewer attribution in header" ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_TestReview_20250522 ;
        oa:hasSelector [ a oa:TextPositionSelector ; oa:start 17 ; oa:end 44 ] ;
        oa:hasSelector [ a oa:TextQuoteSelector ; oa:exact "test+expert-gh@aswritten.ai" ; oa:prefix "- " ; oa:suffix "---" ]
      ] .

    narr:StyleMetrics_TestReview_20250522 a narr:StyleMetrics ;
      skos:broader narr:StyleMetrics ;
      dct:source narr:Sample_TestReview_20250522 ;
      narr:AverageSentenceLength 0 ;
      narr:ActiveVoiceRatio 0.0 ;
      narr:JargonDensity 0.1 .
  }
}