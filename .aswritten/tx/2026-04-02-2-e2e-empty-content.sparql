# Transaction provenance (default graph)
INSERT DATA {
  narr:Tx_20250522T150000Z a prov:Activity ;
    prov:generatedAtTime "2025-05-22T15:00:00Z"^^xsd:dateTime ;
    prov:wasAssociatedWith "aswritten.ai" ;
    prov:wasAttributedTo "test+expert-gh@aswritten.ai" ;
    narr:originPath ".aswritten/memories/2025-05-22-test-review.md" ;
