      skos:note "Meridian selected to replace Zypherion after evaluation revealed Zypherion's critical streaming ingestion gap. Meridian handles both batch and streaming natively. Decision supersedes prior Zypherion adoption." .

    # ── New Claim: Zypherion Streaming Gap ───────────────────────────────────
    narr:Claim_ZypherionStreamingGap a narr:Claim ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      narr:aboutNode narr:Narrative_ZypherionAdoption ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      skos:note "Zypherion lacks streaming ingestion — identified as a critical gap during extended evaluation by Quinton Fairweather (CTO)." ;
      narr:challenges narr:Claim_ZypherionPerformance .

