# ── UPDATE: Narrative_ZypherionAdoption — theme and note now reflect Meridian pivot ──
DELETE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption narr:theme ?oldTheme ;
      skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T150000Z {
    narr:Narrative_ZypherionAdoption narr:theme "Technology adoption pivot: Meridian replaces Zypherion due to streaming capability gap" ;
      skos:note "REVISED: The organisation initially selected Zypherion for analytics but subsequently switched to Meridian after identifying critical streaming ingestion gaps. Meridian handles both batch and streaming natively. Decision attributed to CTO Quinton Fairweather; Q3 2026 migration window retained. Supersedes prior Zypherion adoption narrative." .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption narr:theme ?oldTheme .
    OPTIONAL { narr:Narrative_ZypherionAdoption skos:note ?oldNote . }
  }
} ;

# ── UPDATE: Claim_ZypherionDatabaseChoice — Zypherion is no longer chosen; Meridian is ──
DELETE {
  GRAPH ?g {
    narr:Claim_ZypherionDatabaseChoice skos:note ?oldNote ;
      narr:hasConvictionLevel ?oldLevel .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T150000Z {
    narr:Claim_ZypherionDatabaseChoice skos:note "SUPERSEDED: Zypherion was formally selected as the analytics database but this decision has been explicitly reversed. Meridian is now the chosen database. See narr:Claim_MeridianDatabaseChoice." ;
      narr:hasConvictionLevel narr:Conviction_Notion .
  }
}
WHERE {
  GRAPH ?g {
    narr:Claim_ZypherionDatabaseChoice skos:note ?oldNote ;
      narr:hasConvictionLevel ?oldLevel .
  }
} ;

# ── UPDATE: Claim_ZypherionMigrationQ3 — timeline retained but now for Meridian ──
DELETE {
  GRAPH ?g {
    narr:Claim_ZypherionMigrationQ3 skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T150000Z {
    narr:Claim_ZypherionMigrationQ3 skos:note "Migration to Meridian (formerly planned for Zypherion) is planned to start in Q3 2026. Timeline unchanged from prior decision; now applies to Meridian." .
  }
}
WHERE {
  GRAPH ?g {
    narr:Claim_ZypherionMigrationQ3 skos:note ?oldNote .
  }
} ;

# ── UPDATE: Actor_QuintonFairweather — note updated to reflect revised decision role ──
DELETE {
  GRAPH ?g {
    narr:Actor_QuintonFairweather skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T150000Z {
    narr:Actor_QuintonFairweather skos:note "CTO. Decision-maker for analytics database selection. Initially adopted Zypherion; subsequently reversed to Meridian after identifying critical streaming ingestion gaps (2026-04-06)." .
  }
}
WHERE {
  GRAPH ?g {
    narr:Actor_QuintonFairweather skos:note ?oldNote .
  }
}