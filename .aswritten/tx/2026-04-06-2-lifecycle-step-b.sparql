      narr:supports narr:Narrative_MeridianAdoption .

    # ── Style Observation 1: Direct Declarative Tone ─────────────────────────
    narr:StyleObs_DirectDeclarative a narr:StyleObservation ;
      skos:broader narr:ToneDirectPersonal ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      skos:note "Quinton's quote uses first-person plural declarative: 'We evaluated... We are now switching.' Authoritative, no hedging." ;
      oa:hasTarget [
