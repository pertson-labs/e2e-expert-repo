      dct:source narr:Sample_MeridianDecision_20260406 ;
      skos:broader narr:DataIntegrationFlows ;
      skos:note "Explicit identification of Zypherion's critical gap: lack of streaming ingestion capability." ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 507 ;
        oa:end 542
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "Zypherion lacks streaming ingestion" ;
        oa:prefix "- **Reason**: " ;
        oa:suffix "\n- **Timeline**:"
      ] .

  }
} ;

