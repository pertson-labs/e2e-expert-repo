# ── New Sample for the REVISED document ─────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20250714T120000Z {
    narr:Sample_MeridianDecision_20260406
      a narr:Sample ;
      dct:title "Database Decision REVISED: Switching from Zypherion to Meridian" ;
      dct:created "2026-04-06"^^xsd:date ;
      dct:description "Revised meeting note in which CTO Quinton Fairweather supersedes the prior Zypherion decision and selects Meridian as the analytics database, citing critical gaps in Zypherion's streaming ingestion. Q3 2026 migration window retained." ;
      narr:inputLength 590 .
  }
} ;

# ── UPDATE: Narrative_ZypherionAdoption → now reflects Meridian supersession ─
DELETE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption narr:theme ?oldTheme ;
      skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20250714T120000Z {
    narr:Narrative_ZypherionAdoption
      narr:theme "Switching from Zypherion to Meridian as the analytics database due to streaming ingestion gaps" ;
      skos:note "REVISED 2026-04-06: The organisation has superseded the Zypherion adoption decision and is now switching to Meridian. Zypherion was found to have critical gaps in streaming ingestion; Meridian handles both batch and streaming natively. Q3 2026 migration window is retained." ;
      dct:source narr:Sample_MeridianDecision_20260406 .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption narr:theme ?oldTheme .
    OPTIONAL { narr:Narrative_ZypherionAdoption skos:note ?oldNote . }
  }
} ;

# ── UPDATE: Claim_ZypherionDBSelection → Meridian replaces Zypherion ─────────
DELETE {
  GRAPH ?g {
    narr:Claim_ZypherionDBSelection
      skos:note ?oldNote ;
      narr:hasConvictionLevel ?oldConviction ;
      dct:source ?oldSource .
  }
}
INSERT {
  GRAPH narr:Tx_20250714T120000Z {
    narr:Claim_ZypherionDBSelection
      skos:note "REVISED: Meridian has replaced Zypherion as the selected analytics database. Decision attributed to CTO Quinton Fairweather on 2026-04-06 (revised). Zypherion was rejected due to critical streaming ingestion gaps." ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      dct:source narr:Sample_MeridianDecision_20260406 .
  }
}
WHERE {
  GRAPH ?g {
    narr:Claim_ZypherionDBSelection skos:note ?oldNote ;
      narr:hasConvictionLevel ?oldConviction ;
      dct:source ?oldSource .
  }
} ;

# ── UPDATE: Claim_ZypherionMigrationQ3 → same timeline, now for Meridian ─────
DELETE {
  GRAPH ?g {
    narr:Claim_ZypherionMigrationQ3
      skos:note ?oldNote ;
      dct:source ?oldSource .
  }
}
INSERT {
  GRAPH narr:Tx_20250714T120000Z {
    narr:Claim_ZypherionMigrationQ3
      skos:note "REVISED: Migration timeline of Q3 2026 is retained, but now applies to Meridian (not Zypherion). Conviction remains Stake — timeline stated but not yet confirmed by a project plan." ;
      dct:source narr:Sample_MeridianDecision_20260406 .
  }
}
WHERE {
  GRAPH ?g {
    narr:Claim_ZypherionMigrationQ3 skos:note ?oldNote ;
      dct:source ?oldSource .
  }
} ;

# ── New Claims ───────────────────────────────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20250714T120000Z {

    narr:Claim_ZypherionStreamingGap
      a narr:Claim ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      skos:note "Zypherion has critical gaps in streaming ingestion, as identified during further evaluation by Quinton Fairweather. This is the stated reason for the database switch." ;
      narr:aboutNode narr:Narrative_ZypherionAdoption ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:challenges narr:Claim_ZypherionDBSelection .

    narr:Claim_MeridianStreamingCapability
      a narr:Claim ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      skos:note "Meridian handles both batch and streaming ingestion natively, making it the preferred replacement for Zypherion in the analytics pipeline." ;
      narr:aboutNode narr:Narrative_ZypherionAdoption ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Claim_ZypherionDBSelection .

    narr:Claim_MeridianDBSelection
      a narr:Claim ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      skos:note "Meridian is formally selected as the analytics database, replacing Zypherion. Decision attributed to CTO Quinton Fairweather on 2026-04-06 (revised document)." ;
      narr:aboutNode narr:Narrative_ZypherionAdoption ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_ZypherionAdoption .

  }
} ;

