        oa:exact "This supersedes the previous Zypherion decision." ;
        oa:prefix "Meridian handles both batch and streaming natively.\"\n\n" ;
        oa:suffix "\n\nKey decisions:"
      ] .

    narr:Obs_MeridianReplacementDecision
      a narr:Observation ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      skos:broader narr:StackOverview ;
      skos:note "Quinton's direct statement announcing the switch from Zypherion to Meridian and the reason for it." ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 196 ;
        oa:end 320
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "We evaluated Zypherion further and found critical gaps in\nits streaming ingestion. We are now switching to Meridian instead." ;
        oa:prefix "Quinton: \"" ;
        oa:suffix "\nMeridian handles both batch and streaming natively."
      ] .

    narr:Obs_ZypherionStreamingGapStatement
