# ── UPDATE: Narrative_ZypherionAdoption — mark as superseded ────────────────
DELETE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption narr:theme ?oldTheme ;
      skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T150000Z {
    narr:Narrative_ZypherionAdoption narr:theme "Technology adoption driven by quantified performance gain [SUPERSEDED — see narr:Narrative_MeridianAdoption]" ;
      skos:note "SUPERSEDED 2026-04-06: The organisation initially selected Zypherion for analytics (15x columnar speed). This decision was reversed after critical streaming ingestion gaps were discovered. Meridian was selected instead. See narr:Narrative_MeridianAdoption." ;
      narr:challenges narr:Narrative_MeridianAdoption .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption narr:theme ?oldTheme ;
      skos:note ?oldNote .
  }
} ;

