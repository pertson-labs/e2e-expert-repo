      narr:aboutNode narr:Narrative_MeridianAdoption ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Claim_MeridianForAnalytics ;
      narr:challenges narr:Claim_ZypherionForAnalytics .

    narr:Claim_MigrationQ3_2026_Meridian a narr:Claim ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
