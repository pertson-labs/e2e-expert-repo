# ── New Sample for the revised document ─────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260406T150000Z {
    narr:Sample_MeridianDecision_20260406 a narr:Sample ;
      dct:title "Database Decision REVISED: Switching from Zypherion to Meridian" ;
      dct:created "2026-04-06"^^xsd:date ;
      dct:description "Revised meeting note in which CTO Quinton Fairweather retracts the Zypherion decision and selects Meridian as the analytics database, citing Zypherion's critical streaming ingestion gap. Q3 2026 migration timeline is preserved." ;
      narr:inputLength 541 .
  }
} ;

# ── New Narrative: Meridian adoption supersedes Zypherion ───────────────────
INSERT DATA {
  GRAPH narr:Tx_20260406T150000Z {
    narr:Narrative_MeridianAdoption a narr:Narrative ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      skos:broader narr:StackOverview ;
      narr:theme "Technology re-selection driven by capability gap discovery" ;
      skos:note "After further evaluation, Zypherion was found to lack streaming ingestion. Meridian was selected as its replacement because it handles both batch and streaming natively. This narrative supersedes narr:Narrative_ZypherionAdoption. The Q3 2026 migration window is retained." .
  }
} ;

# ── New Claims ───────────────────────────────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260406T150000Z {

    narr:Claim_MeridianForAnalytics a narr:Claim ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
