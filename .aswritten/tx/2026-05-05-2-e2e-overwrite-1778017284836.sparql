INSERT DATA {
  GRAPH narr:Tx_20250115T130000Z {
    narr:StyleMetrics_SecondVersion a narr:StyleMetrics ;
      dct:source narr:Sample_SecondVersion ;
      skos:broader narr:StyleMetrics ;
      skos:note "Extremely short document (2-word body). Active voice ratio maximal. Zero jargon. Register is informal plain-English. Structurally identical to first version metrics." ;
