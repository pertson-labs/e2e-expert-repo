    narr:Claim_ZypherionPerformance15x ?p ?o .
  }
} ;

# ── INSERT: New Claims and Observations ──────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260406T150000Z {

    # Claim: Zypherion streaming ingestion gap
    narr:Claim_ZypherionStreamingGap a narr:Claim ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:note "Zypherion has critical gaps in streaming ingestion — the primary technical reason for the switch to Meridian." ;
      narr:aboutNode narr:Narrative_MeridianAdoption ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Claim_MeridianDatabaseChoice ;
      narr:challenges narr:Narrative_ZypherionAdoption .

    # Claim: Meridian handles batch and streaming natively
    narr:Claim_MeridianBatchStreamingCapability a narr:Claim ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:note "Meridian handles both batch and streaming ingestion natively — the key differentiator cited by the CTO." ;
      narr:aboutNode narr:Narrative_MeridianAdoption ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Claim_MeridianDatabaseChoice .

    # Observation: Quinton's direct statement on Meridian
    narr:Obs_QuintonMeridianStatement a narr:Observation ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:broader narr:PrimaryActors ;
      skos:note "CTO direct statement announcing switch to Meridian and citing streaming ingestion gap in Zypherion." ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 155 ;
        oa:end 310
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "We evaluated Zypherion further and found critical gaps in its streaming ingestion. We are now switching to Meridian instead." ;
        oa:prefix "Quinton: \"" ;
        oa:suffix "\nMeridian handles both batch"
      ] .

    # Observation: Supersession statement
    narr:Obs_SupersessionStatement a narr:Observation ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:broader narr:DesignTradeoffs ;
      skos:note "Explicit retraction of prior Zypherion decision." ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 325 ;
        oa:end 374
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "This supersedes the previous Zypherion decision." ;
        oa:prefix "natively.\"\n\n" ;
        oa:suffix "\n\nKey decisions:"
      ] .

    # Observation: Meridian technical rationale
    narr:Obs_MeridianRationale a narr:Observation ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:broader narr:DataIntegrationFlows ;
      skos:note "Meridian's dual batch+streaming capability is the stated technical rationale for selection." ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 285 ;
        oa:end 330
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "Meridian handles both batch and streaming natively." ;
        oa:prefix "switching to Meridian instead.\n" ;
        oa:suffix "\"\n\nThis supersedes"
      ] .

    # Style Observation 1: Direct authoritative tone
    narr:StyleObs_DirectDeclarativeTone_Meridian a narr:StyleObservation ;
      skos:broader narr:ToneAuthoritative ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:note "Declarative, first-person plural assertions with no hedging. Institutional authority voice." ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_MeridianDBDecision_20260406 ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 155 ;
          oa:end 220
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "We evaluated Zypherion further and found critical gaps" ;
          oa:prefix "Quinton: \"" ;
          oa:suffix " in\nits streaming ingestion."
        ]
      ] .

    # Style Observation 2: Bullet-structured key decisions
    narr:StyleObs_BulletStructure_Meridian a narr:StyleObservation ;
      skos:broader narr:GrammarSyntax ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:note "Key decisions formatted as bold-label bullet list: Database, Reason, Timeline. Parallel structure enforces scanability." ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_MeridianDBDecision_20260406 ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 376 ;
          oa:end 469
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "- **Database**: Meridian replaces Zypherion for analytics" ;
          oa:prefix "Key decisions:\n" ;
          oa:suffix "\n- **Reason**: Zypherion lacks"
        ]
      ] .

    # Style Observation 3: Bold key-term emphasis
    narr:StyleObs_BoldKeyTerms_Meridian a narr:StyleObservation ;
      skos:broader narr:CapitalizationCase ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:note "Markdown bold used for category labels (Database, Reason, Timeline) to signal structured decision record format." ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_MeridianDBDecision_20260406 ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 390 ;
          oa:end 430
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "**Database**: Meridian replaces Zypherion" ;
          oa:prefix "- " ;
          oa:suffix " for analytics"
        ]
      ] .

    # Style Metrics
    narr:StyleMetrics_MeridianDBDecision a narr:StyleMetrics ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:broader narr:StyleMetrics ;
      narr:AverageSentenceLength 13 ;
      narr:ActiveVoiceRatio "0.92"^^xsd:decimal ;
      narr:JargonDensity "0.14"^^xsd:decimal ;
      skos:note "Short declarative sentences; high active voice; moderate technical jargon (streaming ingestion, batch, analytics pipeline, migration). Formal institutional register with named-speaker attribution and explicit supersession language." .
