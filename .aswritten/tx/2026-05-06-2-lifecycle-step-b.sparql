# ── New Sample for the revised document ─────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260406T150000Z {
    narr:Sample_ZypherionDecisionRevised_20260406 a narr:Sample ;
      dct:title "Database Decision REVISED: Switching from Zypherion to Meridian" ;
      dct:description "Revised meeting notes (2026-04-06) recording CTO Quinton Fairweather's decision to switch from Zypherion to Meridian for analytics, citing critical gaps in Zypherion's streaming ingestion. Explicitly supersedes the prior Zypherion adoption decision. Q3 2026 migration window retained." ;
      dct:created "2026-04-06"^^xsd:date ;
      narr:inputLength "592"^^xsd:integer .
  }
} ;

# ── UPDATE: Narrative_ZypherionAdoption → now reflects Meridian adoption ────
# Justified: memory states "We are now switching to Meridian instead" and
# "This supersedes the previous Zypherion decision" — explicit retraction.
DELETE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption
      skos:note ?oldNote ;
      narr:theme ?oldTheme .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T150000Z {
    narr:Narrative_ZypherionAdoption
      dct:source narr:Sample_ZypherionDecisionRevised_20260406 ;
      skos:note "REVISED: The organisation is switching from Zypherion to Meridian for analytics. Zypherion was found to have critical gaps in streaming ingestion; Meridian handles both batch and streaming natively. This supersedes the prior Zypherion adoption decision. Q3 2026 migration window is retained." ;
      narr:theme "Technology platform reversal driven by capability gap discovery" .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption
      skos:note ?oldNote ;
      narr:theme ?oldTheme .
  }
} ;

# ── UPDATE: Claim_ZypherionDatabaseSelection → Meridian selected instead ────
# Justified: "Meridian replaces Zypherion for analytics" — functional change
# (database selection is single-valued; Meridian is now the chosen platform).
DELETE {
  GRAPH ?g {
    narr:Claim_ZypherionDatabaseSelection
      skos:note ?oldNote ;
      narr:hasConvictionLevel ?oldLevel ;
      narr:aboutNode ?oldAbout .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T150000Z {
    narr:Claim_ZypherionDatabaseSelection
      dct:source narr:Sample_ZypherionDecisionRevised_20260406 ;
      skos:note "REVISED: Meridian (not Zypherion) has been selected as the database for the analytics pipeline. Decision attributed to CTO Quinton Fairweather. Zypherion was rejected due to critical streaming ingestion gaps." ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:aboutNode narr:Narrative_ZypherionAdoption .
  }
}
WHERE {
  GRAPH ?g {
    narr:Claim_ZypherionDatabaseSelection
      skos:note ?oldNote ;
      narr:hasConvictionLevel ?oldLevel ;
      narr:aboutNode ?oldAbout .
  }
} ;

