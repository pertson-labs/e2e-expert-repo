# ── New Sample ───────────────────────────────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260406T150000Z {
    narr:Sample_MeridianDBDecision_20260406 a narr:Sample ;
      dct:title "Database Decision REVISED: Switching from Zypherion to Meridian" ;
      dct:created "2026-04-06"^^xsd:date ;
      narr:inputLength 469 ;
      skos:note "Revised meeting note from CTO Quinton Fairweather superseding the prior Zypherion adoption decision. Meridian selected for analytics due to native batch and streaming ingestion support. Q3 2026 migration timeline retained." .
  }
} ;

# ── UPDATE: Narrative_ZypherionAdoption → Meridian ───────────────────────────
DELETE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption
      narr:theme ?oldTheme ;
      skos:note ?oldNote ;
      dct:source ?oldSource .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T150000Z {
    narr:Narrative_MeridianAdoption a narr:Narrative ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      skos:broader narr:StackOverview ;
      narr:theme "Technology adoption driven by streaming ingestion capability" ;
      skos:note "The organisation is switching from Zypherion to Meridian for analytics, citing Zypherion's critical gap in streaming ingestion. Meridian handles both batch and streaming natively. Migration remains Q3 2026. This supersedes the prior Zypherion adoption narrative." ;
      narr:supersedes narr:Narrative_ZypherionAdoption .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption narr:theme ?oldTheme .
    OPTIONAL { narr:Narrative_ZypherionAdoption skos:note ?oldNote . }
    OPTIONAL { narr:Narrative_ZypherionAdoption dct:source ?oldSource . }
  }
} ;

# ── UPDATE: Claim_ZypherionDatabaseChoice → Meridian ─────────────────────────
DELETE {
  GRAPH ?g {
    narr:Claim_ZypherionDatabaseChoice
