# ── INSERT: New Narrative for Meridian (distinct from the updated Zypherion node)
INSERT DATA {
  GRAPH narr:Tx_20260406T130000Z {

    narr:Narrative_MeridianAdoption a narr:Narrative ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      skos:broader narr:StackOverview ;
      narr:theme "Meridian selected as analytics database for native batch and streaming support" ;
      skos:note "Meridian is chosen to replace Zypherion because it handles both batch and streaming ingestion natively, addressing the critical gap that disqualified Zypherion. Migration window remains Q3 2026." .

    # New claim: Zypherion streaming gap (new knowledge, not in snapshot)
    narr:Claim_ZypherionStreamingGap a narr:Claim ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      narr:aboutNode narr:Narrative_MeridianAdoption ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:challenges narr:Narrative_ZypherionAdoption ;
      skos:note "Zypherion was evaluated further and found to have critical gaps in streaming ingestion, disqualifying it from the analytics pipeline role." .

    # New claim: Meridian batch+streaming capability (new knowledge)
    narr:Claim_MeridianBatchStreamingCapability a narr:Claim ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      narr:aboutNode narr:Narrative_MeridianAdoption ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_MeridianAdoption ;
      skos:note "Meridian handles both batch and streaming ingestion natively, making it the replacement for Zypherion in the analytics pipeline." .

    # Alias claim nodes for the revised decision
    narr:Claim_MeridianDatabaseSelection a narr:Claim ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      narr:aboutNode narr:Narrative_MeridianAdoption ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_MeridianAdoption ;
      skos:note "Meridian selected as the analytics database, replacing Zypherion. Decision attributed to CTO Quinton Fairweather on 2026-04-06." .

    narr:Claim_MeridianMigrationQ3_2026 a narr:Claim ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      narr:aboutNode narr:Narrative_MeridianAdoption ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Claim_MeridianDatabaseSelection ;
      skos:note "Migration to Meridian is scheduled for the same Q3 2026 window originally planned for Zypherion." .

    # Observation: Quinton's supersession statement
    narr:Obs_QuintonSupersessionStatement a narr:Observation ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      skos:broader narr:StrategyOverview ;
      skos:note "CTO explicitly supersedes prior Zypherion decision and announces Meridian switch" ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 196 ;
        oa:end 373
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "We evaluated Zypherion further and found critical gaps in its streaming ingestion. We are now switching to Meridian instead." ;
        oa:prefix "Quinton: \"" ;
        oa:suffix " Meridian handles both batch"
      ] .

    # Observation: Key decisions list
    narr:Obs_MeridianKeyDecisions a narr:Observation ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      skos:broader narr:FocusSequencing ;
      skos:note "Structured key decisions: Meridian replaces Zypherion, reason is streaming gap, timeline is Q3 2026" ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 439 ;
        oa:end 592
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "Meridian replaces Zypherion for analytics" ;
        oa:prefix "- **Database**: " ;
        oa:suffix "\n- **Reason**: Zypherion"
      ] .

    # Style Observation 1: Authoritative declarative tone
    narr:StyleObs_AuthoritativeTone_Meridian a narr:StyleObservation ;
      skos:broader narr:ToneAuthoritative ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      skos:note "First-person plural declarative: 'We are now switching' asserts decision with no hedging" ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_MeridianDecision_20260406 ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 255 ;
          oa:end 296
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "We are now switching to Meridian instead." ;
          oa:prefix "its streaming ingestion. " ;
          oa:suffix " Meridian handles both"
        ]
      ] .

    # Style Observation 2: Short punchy cadence
    narr:StyleObs_ShortPunchyCadence_Meridian a narr:StyleObservation ;
      skos:broader narr:ShortPunchyCadence ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      skos:note "Single declarative sentence closes the rationale with a capability statement — no subordinate clauses" ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_MeridianDecision_20260406 ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 297 ;
          oa:end 348
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "Meridian handles both batch and streaming natively." ;
          oa:prefix "switching to Meridian instead. " ;
          oa:suffix "\"\n\nThis supersedes"
        ]
      ] .

    # Style Observation 3: Technical jargon density
    narr:StyleObs_JargonDensity_Meridian a narr:StyleObservation ;
      skos:broader narr:JargonPolicy ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      skos:note "Technical terms 'streaming ingestion' and 'batch and streaming' used without definition, assuming engineering audience" ;
      rdf:value false ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_MeridianDecision_20260406 ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 505 ;
          oa:end 540
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "Zypherion lacks streaming ingestion" ;
          oa:prefix "- **Reason**: " ;
          oa:suffix "\n- **Timeline**:"
        ]
      ] .

    # Style Metrics for revised document
    narr:StyleMetrics_MeridianDecision a narr:StyleMetrics ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      skos:broader narr:StyleMetrics ;
      skos:note "Short declarative register. High active-voice ratio from first-person plural announcements. Moderate jargon density from technical terms (streaming ingestion, batch and streaming, analytics pipeline, migration window)." ;
      narr:AverageSentenceLength "13"^^xsd:integer ;
      narr:ActiveVoiceRatio "0.88"^^xsd:decimal ;
      narr:JargonDensity "0.20"^^xsd:decimal .
  }
}