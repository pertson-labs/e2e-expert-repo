INSERT {
  GRAPH narr:Tx_20260406T130000Z {
    narr:Narrative_ZypherionAdoption
      narr:theme "Switching from Zypherion to Meridian as the analytics database due to streaming ingestion gaps" ;
      skos:note "REVISED: The organisation is replacing Zypherion with Meridian for its analytics pipeline. Zypherion was found to have critical gaps in streaming ingestion; Meridian handles both batch and streaming natively. Migration remains scheduled for Q3 2026. This supersedes the prior Zypherion adoption decision." ;
      skos:broader narr:StackOverview .
  }
}
