      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start "497"^^xsd:integer ;
        oa:end "547"^^xsd:integer
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "Zypherion lacks streaming ingestion" ;
        oa:prefix "- **Reason**: " ;
        oa:suffix "\n- **Timeline**"
      ] .

    narr:Obs_MeridianNativeCapability a narr:Observation ;
      skos:broader narr:StackOverview ;
      dct:source narr:Sample_ZypherionDecisionRevised_20260406 ;
      skos:note "Meridian's key differentiator: native support for both batch and streaming ingestion, directly addressing the gap that eliminated Zypherion." ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start "321"^^xsd:integer ;
        oa:end "373"^^xsd:integer
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "Meridian handles both batch and streaming natively." ;
        oa:prefix "We are now switching to Meridian instead.\n" ;
        oa:suffix "\"\n\nThis supersedes"
      ] .

  }
} ;

