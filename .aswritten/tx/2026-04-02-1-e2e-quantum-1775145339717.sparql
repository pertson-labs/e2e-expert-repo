        oa:hasSource narr:Sample_ExpertReview_20250514 ;
        oa:hasSelector [ a oa:TextPositionSelector ; oa:start 48 ; oa:end 52 ] ;
        oa:hasSelector [ a oa:TextQuoteSelector ; oa:exact "\n\n" ; oa:prefix "---" ; oa:suffix "" ]
      ] ;
