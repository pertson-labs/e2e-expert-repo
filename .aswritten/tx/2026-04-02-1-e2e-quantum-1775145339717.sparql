        oa:hasSource narr:Sample_ExpertReview_20250514 ;
        oa:hasSelector [ a oa:TextPositionSelector ; oa:start 0 ; oa:end 48 ] ;
        oa:hasSelector [ a oa:TextQuoteSelector ; oa:exact "---\nreviewers:\n  - test+expert-gh@aswritten.ai\n---" ; oa:prefix "" ; oa:suffix "\n\n" ]
      ] ;
      skos:note "Use of YAML frontmatter for metadata." .

    narr:StyleObservation_ReviewerAssignment_20250514 a narr:StyleObservation ;
      skos:broader narr:Process ;
      dct:source narr:Sample_ExpertReview_20250514 ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_ExpertReview_20250514 ;
        oa:hasSelector [ a oa:TextPositionSelector ; oa:start 15 ; oa:end 44 ] ;
        oa:hasSelector [ a oa:TextQuoteSelector ; oa:exact "test+expert-gh@aswritten.ai" ; oa:prefix "reviewers:\n  - " ; oa:suffix "\n---" ]
      ] ;
      skos:note "Explicit reviewer assignment in metadata." .

    narr:StyleObservation_EmptyBody_20250514 a narr:StyleObservation ;
      skos:broader narr:Conciseness ;
      dct:source narr:Sample_ExpertReview_20250514 ;
      oa:hasTarget [
