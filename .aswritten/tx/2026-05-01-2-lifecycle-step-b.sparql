# ── New Sample for the revised document ─────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260406T140000Z {
    narr:Sample_MeridianDecision_20260406 a narr:Sample ;
      dct:title "Database Decision REVISED: Switching from Zypherion to Meridian" ;
      dct:created "2026-04-06"^^xsd:date ;
      dct:description "Revised meeting note in which CTO Quinton Fairweather retracts the Zypherion decision and selects Meridian as the analytics database, citing critical streaming ingestion gaps in Zypherion. Migration window remains Q3 2026." ;
      narr:inputLength 541 .
  }
} ;

# ── New Narrative: Meridian Adoption ────────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260406T140000Z {
    narr:Narrative_MeridianAdoption a narr:Narrative ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      skos:broader narr:StackOverview ;
      narr:theme "Technology pivot driven by critical capability gap discovery" ;
      skos:note "The organisation reverses its Zypherion analytics database decision after discovering critical streaming ingestion gaps, and adopts Meridian — which handles both batch and streaming natively — within the same Q3 2026 migration window." .
  }
} ;

