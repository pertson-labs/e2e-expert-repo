# ── UPDATE: narr:Narrative_ZypherionAdoption → now Meridian adoption ─────────
DELETE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption narr:theme ?oldTheme ;
      skos:note ?oldNote ;
      dct:source ?oldSource .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T150000Z {
    narr:Narrative_ZypherionAdoption narr:theme "Strategic pivot from Zypherion to Meridian as the analytics database" ;
      skos:note "The organisation reversed its Zypherion database decision after finding critical gaps in streaming ingestion. Meridian was selected as the replacement, handling both batch and streaming natively. The Q3 2026 migration window is retained." ;
      dct:source narr:Sample_MeridianDecision_20260406 .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption narr:theme ?oldTheme .
    OPTIONAL { narr:Narrative_ZypherionAdoption skos:note ?oldNote . }
    OPTIONAL { narr:Narrative_ZypherionAdoption dct:source ?oldSource . }
  }
} ;

# ── UPDATE: narr:Claim_ZypherionDatabaseChoice → now Meridian ────────────────
DELETE {
  GRAPH ?g {
    narr:Claim_ZypherionDatabaseChoice skos:note ?oldNote ;
      dct:source ?oldSource ;
      narr:hasConvictionLevel ?oldLevel .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T150000Z {
    narr:Claim_ZypherionDatabaseChoice skos:note "Meridian selected as the database for the analytics pipeline, replacing Zypherion. Decision attributed to CTO Quinton Fairweather. Supersedes prior Zypherion selection." ;
      dct:source narr:Sample_MeridianDecision_20260406 ;
      narr:hasConvictionLevel narr:Conviction_Boulder .
  }
}
WHERE {
  GRAPH ?g {
    narr:Claim_ZypherionDatabaseChoice narr:hasConvictionLevel ?oldLevel .
    OPTIONAL { narr:Claim_ZypherionDatabaseChoice skos:note ?oldNote . }
    OPTIONAL { narr:Claim_ZypherionDatabaseChoice dct:source ?oldSource . }
  }
} ;

