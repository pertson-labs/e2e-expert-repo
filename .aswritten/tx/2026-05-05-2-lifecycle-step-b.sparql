# ── New Sample for the REVISED document ─────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20250714T000000Z {
    narr:Sample_MeridianDBDecision_20260406
      a narr:Sample ;
      dct:title "Database Decision REVISED: Switching from Zypherion to Meridian" ;
      dct:created "2026-04-06"^^xsd:date ;
      dct:description "Revised meeting note in which CTO Quinton Fairweather retracts the Zypherion decision and adopts Meridian for the analytics pipeline, citing critical streaming ingestion gaps in Zypherion and Meridian's native batch+streaming support. Q3 2026 migration window unchanged." ;
      narr:inputLength 520 .
  }
} ;

# ── UPDATE: Narrative_ZypherionAdoption → now Meridian adoption ──
DELETE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption
      narr:theme ?oldTheme ;
      skos:note  ?oldNote ;
      dct:source ?oldSource .
  }
}
INSERT {
  GRAPH narr:Tx_20250714T000000Z {
    narr:Narrative_ZypherionAdoption
      narr:theme "Replacing Zypherion with Meridian as the analytics database due to streaming ingestion gaps" ;
      skos:note  "The organisation has reversed its Zypherion decision. CTO Quinton Fairweather identified critical streaming ingestion gaps in Zypherion and is now adopting Meridian, which handles both batch and streaming natively. The Q3 2026 migration window is unchanged." ;
      dct:source narr:Sample_MeridianDBDecision_20260406 .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_ZypherionAdoption
      narr:theme ?oldTheme .
    OPTIONAL { narr:Narrative_ZypherionAdoption skos:note  ?oldNote . }
    OPTIONAL { narr:Narrative_ZypherionAdoption dct:source ?oldSource . }
  }
} ;

# ── UPDATE: Claim_ZypherionForAnalytics → now Meridian for analytics ──
DELETE {
  GRAPH ?g {
    narr:Claim_ZypherionForAnalytics
      skos:note  ?oldNote ;
      dct:source ?oldSource ;
      narr:hasConvictionLevel ?oldConviction .
  }
}
INSERT {
  GRAPH narr:Tx_20250714T000000Z {
    narr:Claim_ZypherionForAnalytics
      skos:note  "Quinton Fairweather (CTO) has reversed the Zypherion decision and explicitly adopted Meridian for the analytics pipeline, citing critical streaming ingestion gaps in Zypherion." ;
      dct:source narr:Sample_MeridianDBDecision_20260406 ;
      narr:hasConvictionLevel narr:Conviction_Boulder .
  }
}
WHERE {
  GRAPH ?g {
    narr:Claim_ZypherionForAnalytics
      narr:hasConvictionLevel ?oldConviction .
    OPTIONAL { narr:Claim_ZypherionForAnalytics skos:note  ?oldNote . }
    OPTIONAL { narr:Claim_ZypherionForAnalytics dct:source ?oldSource . }
  }
} ;

# ── UPDATE: Claim_MigrationQ3_2026 → same timeline, now for Meridian ──
DELETE {
  GRAPH ?g {
    narr:Claim_MigrationQ3_2026
      skos:note  ?oldNote ;
      dct:source ?oldSource .
  }
}
INSERT {
  GRAPH narr:Tx_20250714T000000Z {
    narr:Claim_MigrationQ3_2026
      skos:note  "Migration to Meridian (replacing Zypherion) is scheduled for the same Q3 2026 window, as confirmed by the CTO in the revised decision." ;
      dct:source narr:Sample_MeridianDBDecision_20260406 .
  }
}
WHERE {
  GRAPH ?g {
    narr:Claim_MigrationQ3_2026
      narr:aboutNode narr:Narrative_ZypherionAdoption .
    OPTIONAL { narr:Claim_MigrationQ3_2026 skos:note  ?oldNote . }
    OPTIONAL { narr:Claim_MigrationQ3_2026 dct:source ?oldSource . }
  }
} ;

