    narr:Obs_QuintonAdoptionStatement skos:broader narr:StackOverview .
    OPTIONAL { narr:Obs_QuintonAdoptionStatement skos:note  ?oldNote . }
    OPTIONAL { narr:Obs_QuintonAdoptionStatement dct:source ?oldSource . }
  }
} ;

